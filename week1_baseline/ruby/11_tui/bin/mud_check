#!/usr/bin/env ruby
$LOAD_PATH.unshift File.expand_path("../lib", __dir__)
require "mud_manager"

s = MudManager::Session.new(host:"localhost", port:4000, timeout:5)
s.open; s.login("dummy", "helloworld")

def c(t)
  $s.drain; $s.send_command(t); $s.read_until_prompt(timeout:5)
end
$s = s
$stdout.sync = true

def st(t); t.gsub(/\e\[[\d;]*m/,""); end

# First, recall to temple
r = c("recall")
puts "RECALL: #{st(r).lines.first&.strip}"

# Now explore from temple
path = %w[s s e w n d u]
path.each do |d|
  r = c(d)
  rt = st(r)
  next if rt.include?("can't go")
  name = rt.lines.first&.strip || "?"
  exits = rt[/\[ Exits: ([^\]]+)\s*\]/, 1] || "?"
  mobs = rt.each_line.select { |l| l.match?(/\s+is\s+(here|standing|sitting|resting|lying)/i) }
  puts "#{d}: #{name} [Exits: #{exits}]"
  mobs.each { |m| puts "    #{m.strip}" }
end

s.close
